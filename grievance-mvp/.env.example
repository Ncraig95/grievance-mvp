
# Grievance API
API_PORT=8080

# DocuSeal Database
DOCUSEAL_DB_USER=docuseal
DOCUSEAL_DB_PASSWORD=docuseal
DOCUSEAL_DB_NAME=docuseal

# DocuSeal App
DOCUSEAL_IMAGE=docuseal/docuseal:2.3.0
DOCUSEAL_PORT=8081
DOCUSEAL_PROTOCOL=https
DOCUSEAL_HOST=docuseal.example.com
DOCUSEAL_ADMIN_EMAIL=admin@example.com
DOCUSEAL_ADMIN_PASSWORD=password
DOCUSEAL_WEB_BASE_URL=https://docuseal.example.com
DOCUSEAL_WEB_EMAIL=admin@example.com
DOCUSEAL_WEB_PASSWORD=password
DOCUSEAL_WEBHOOK_TARGET_URL=https://api.example.com/webhook/docuseal
DOCUSEAL_WEBHOOK_HEADER_NAME=X-Webhook-Token
DOCUSEAL_WEBHOOK_SECRET=

# Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=
GRIEVANCE_DOMAIN=example.com

# Optional intake endpoint hardening
INTAKE_SHARED_HEADER_VALUE=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
